{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "verbose": true,
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1",
    "^@/(.*)\\.js$": "<rootDir>/../../ioredis/lib/$1",
    "^@/(.*)$": "<rootDir>/../../ioredis/lib/$1",
    "^@health/(.*)\\.js$": "<rootDir>/../lib/$1",
    "^@health/(.*)$": "<rootDir>/../lib/$1"
  },
  "setupFilesAfterEnv": ["jest-extended/all"]
}
